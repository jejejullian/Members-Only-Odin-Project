<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign-Up Form</title>
  </head>
  <body>
    <h1>Daftar Akun</h1>
    <form action="/sign-up" method="post">
      <label for="first_name">First Name:</label>
      <input id="first_name" name="first_name" placeholder="Masukkan Nama Awal" type="text" required />
      <br />
      <label for="last_name">Lasr Name:</label>
      <input id="last_name" name="last_name" placeholder="Masukkan Nama Akhir" type="text" required />
      <br />
      <label for="username">Username:</label>
      <input id="username" name="username" placeholder="Username Anda" type="text" required />
      <br />
      <label for="password">Password:</label>
      <input id="password" name="password" type="password" required />
      <br />
      <label for="confirm_password">Confirm Password</label>
      <input id="confirm_password" name="confirm_password" type="password" required />
      <br>
      <button type="submit">Daftar Akun</button>
    </form>
    <p>Sudah punya akun? <a href="/">Masuk Akun</a></p>
  </body>
</html>
